{
  "name": "company/notification-chat-app",
  "description": "Notification 1:1チャットアプリ - RHEL8相当(UBI8) + Apache + PHP7.4 + PostgreSQL",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^7.4",
    "ext-pdo": "*",
    "ext-pgsql": "*",
    "ext-mbstring": "*",
    "ext-json": "*",
    "vlucas/phpdotenv": "^5.4"
  },
  "require-dev": {
    "phpunit/phpunit": "9.5.28",
    "squizlabs/php_codesniffer": "^3.6"
  },
  "autoload": {
    "psr-4": {
      "Lib\\": "src/lib/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test:coverage": "phpunit --coverage-html tests/coverage/html",
    "test:coverage-text": "phpunit --coverage-text",
    "phpcs": "phpcs --standard=PSR12 app/",
    "phpcbf": "phpcbf --standard=PSR12 app/"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  }
}
